/*! normalize.css v8.0.1 | MIT License | github.com/necolas/normalize.css */
html {
  line-height: 1.15;
  -webkit-text-size-adjust: 100%;
}
body {
  margin: 0;
}
main {
  display: block;
}
h1 {
  font-size: 2em;
  margin: 0.67em 0;
}
hr {
  box-sizing: content-box;
  height: 0;
  overflow: visible;
}
pre {
  font-family: monospace, monospace;
  font-size: 1em;
}
a {
  background-color: transparent;
}
abbr[title] {
  border-bottom: 0;
  text-decoration: underline;
  text-decoration: underline dotted;
}
b,
strong {
  font-weight: bolder;
}
code,
kbd,
samp {
  font-family: monospace, monospace;
  font-size: 1em;
}
small {
  font-size: 80%;
}
sub,
sup {
  font-size: 75%;
  line-height: 0;
  position: relative;
  vertical-align: baseline;
}
sub {
  bottom: -0.25em;
}
sup {
  top: -0.5em;
}
img {
  border-style: none;
}
button,
input,
optgroup,
select,
textarea {
  font-family: inherit;
  font-size: 100%;
  line-height: 1.15;
  margin: 0;
}
button,
input {
  overflow: visible;
}
button,
select {
  text-transform: none;
}
button,
[type="button"],
[type="reset"],
[type="submit"] {
  -webkit-appearance: button;
}
button::-moz-focus-inner,
[type="button"]::-moz-focus-inner,
[type="reset"]::-moz-focus-inner,
[type="submit"]::-moz-focus-inner {
  border-style: none;
  padding: 0;
}
button:-moz-focusring,
[type="button"]:-moz-focusring,
[type="reset"]:-moz-focusring,
[type="submit"]:-moz-focusring {
  outline: 1px dotted ButtonText;
}
fieldset {
  padding: 0.35em 0.75em 0.625em;
}
legend {
  box-sizing: border-box;
  color: inherit;
  display: table;
  max-width: 100%;
  padding: 0;
  white-space: normal;
}
progress {
  vertical-align: baseline;
}
textarea {
  overflow: auto;
}
[type="checkbox"],
[type="radio"] {
  box-sizing: border-box;
  padding: 0;
}
[type="number"]::-webkit-inner-spin-button,
[type="number"]::-webkit-outer-spin-button {
  height: auto;
}
[type="search"] {
  -webkit-appearance: textfield;
  outline-offset: -2px;
}
[type="search"]::-webkit-search-decoration {
  -webkit-appearance: none;
}
::-webkit-file-upload-button {
  -webkit-appearance: button;
  font: inherit;
}
details {
  display: block;
}
summary {
  display: list-item;
}
template {
  display: none;
}
[hidden] {
  display: none;
}

/* design start */
* {
  box-sizing: border-box;
}
body {
  padding-top: 6px;
  /* font-family: "PingFangTC-Regular", "Heiti TC", "Noto Sans TC", "Microsoft JhengHei", "Helvetica Neue", Helvetica, Arial, sans-serif; */
  /* color: #ba9063; */
  /* background: url(../img/bg.jpg) 0% 0% repeat-x #a8a8a8; */
  background: url(../img/bg.jpg) 0% 0% repeat-x #a8a8a8;
}
img,
a {
  display: block;
}
.container {
  width: 655px;
  margin: 0 auto;
  position: relative;
}
.banner1 {
  width: 445px;
  height: 120px;
  position: absolute;
  left: 0;
  top: 0;
}
.banner1 img {
  width: 100%;
  height: 100%;
}
#bulletin {
  width: 445px;
  height: 94px;
  overflow: auto;
  position: absolute;
  left: 0;
  top: 130px;
}
#bulletin a {
  padding: 8px 0;
  font-size: 11px;
  color: #3c3c3c;
  text-decoration: none;
  font-family: Arial, Helvetica, sans-serif;
  background: url(../img/border-dotted.gif) 0% 100% repeat-x;
}
#bulletin a:hover {
  color: #b71414;
}
#bulletin span {
  width: 46px;
  height: 12px;
  margin-right: 5px;
  background-repeat: no-repeat;
  background-position: 0% 0%;
  vertical-align: middle;
  display: inline;
  display: inline-block;
  zoom: 1;
}
#bulletin span.cate-etc {
  background-image: url(../img/cate-etc.gif);
}
#bulletin span.cate-new {
  background-image: url(../img/cate-new.gif);
}
#bulletin span.cate-event {
  background-image: url(../img/cate-event.gif);
}
#bulletin span.cate-buglogs {
  background-image: url(../img/cate-buglogs.gif);
}
#bulletin span.cate-lock {
  background-image: url(../img/cate-lock.gif);
}
#bulletin span.cate-match {
  background-image: url(../img/cate-match.gif);
}
#bulletin span.cate-prize {
  background-image: url(../img/cate-prize.gif);
}
#bulletin span.cate-system {
  background-image: url(../img/cate-system.gif);
}
#bulletin span.cate-update {
  background-image: url(../img/cate-update.gif);
}
.side-content {
  width: 200px;
  position: absolute;
  top: 0;
  right: 0;
  overflow: auto;
}
.side-content:after {
  content: "";
  clear: both;
  display: table;
}
.btn-patch {
  width: 200px;
  height: 57px;
  margin-bottom: 6px;
  background: url(../img/btn-changelog.png) 0% 0% no-repeat;
  cursor: pointer;
}
.banner2 {
  width: 200px;
  height: 57px;
  margin-bottom: 6px;
}
.banner2 img {
  width: 100%;
  height: 100%;
}
.btn-apply {
  width: 200px;
  height: 28px;
  margin-bottom: 6px;
  background: url(../img/btn-mediasocial.png) 0% 0% no-repeat;
  cursor: pointer;
  border: none;
}

.img-qr {
  width: 65px;
  height: auto;
}

.dana-category {
  margin: 0;
  padding: 0;
  width: 65px;
}

.support-content {
  font-size: 10px;
  color: #2270d6;
  font-family: sans-serif;
  font-weight: bold;
  cursor: default;
}

.btn-none {
  width: 200px;
  height: 28px;
  margin-bottom: 6px;
  border: none;
}

.mt-10 {
  margin-top: 10px;
}
.mt-20 {
  margin-top: 20px;
}
.btn-secondary {
  /* background: url(../img/btn-forget.png) 0% 0% no-repeat;
  float: left; */
  background: url(../img/btn-forget.png) 0% 0% no-repeat;
  cursor: pointer;
}
.btn-buglogs {
  /* background: url(../img/btn-forget.png) 0% 0% no-repeat;
  float: left; */
  background: url(../img/btn-buglogs.png) 0% 0% no-repeat;
  cursor: pointer;
}
.btn-password {
  background: url(../img/btn-password.png) 0% 0% no-repeat;
  float: right;
}
.btn-home {
  background: url(../img/btn-home.png) 0% 0% no-repeat;
  float: left;
}
.btn-hk {
  background: url(../img/btn-hk.png) 0% 0% no-repeat;
  float: right;
}
.btn-password,
.btn-home,
.btn-hk {
  width: 95px;
  height: 28px;
  margin-bottom: 6px;
}
.btn-home,
.btn-hk {
  margin-bottom: 0;
}
.btn-patch:hover,
.btn-apply:hover,
.btn-forget:hover,
.btn-password:hover,
.btn-home:hover,
.btn-hk:hover {
  background-position: 0 100%;
}

#alertWrap {
  width: 100%;
  height: 100%;
  text-align: center;
  position: fixed;
  left: 0;
  top: 0;
  background: url(../img/bg-alert.png) 0% 0%;
  display: none;
}
#alertWrap .before {
  height: 100%;
  vertical-align: middle;
  display: inline-block;
}
#alertText {
  color: #fff;
  line-height: 1.4;
  vertical-align: middle;
  display: inline-block;
}

.cursor-pointer {
  cursor: pointer;
}

.versionText {
  margin-top: -30px;
  margin-left: 12px;
  color: white;
  font-size: 18px;
  font-weight: bold;
  font-family: Arial, Helvetica, sans-serif;
  width: auto;
  height: auto;
}
